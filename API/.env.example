# Copia este ficheiro para .env e preenche os valores reais.
# Nenhum destes valores deve ser commitado no git.

# --- Base de dados (Postgres) ---
DATABASE_URL=postgres://user:password@localhost:5432/badgespint

# --- Autenticação ---
JWT_SECRET=uma-chave-secreta-longa-e-aleatoria

# --- URLs públicas (usadas em emails, páginas de partilha OG, certificados) ---
FRONTEND_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:4000
PUBLIC_API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
APP_BASE_URL=http://localhost:4000
PUBLIC_FRONTEND_URL=http://localhost:5173

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- SMTP (envio de emails via nodemailer) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Cloudinary (upload de imagens/evidências) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Hugging Face (geração de imagem de badges, opcional) ---
HF_API_TOKEN=
HF_MODEL_ID=

# --- Firebase Cloud Messaging (push notifications) ---
# Obtidos na consola Firebase: Definições do Projeto > Contas de Serviço > Gerar nova chave privada
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Jobs em background ---
SLA_ALERT_JOB_ENABLED=true
SLA_ALERT_JOB_INTERVAL_MS=3600000
GOAL_REMINDER_JOB_ENABLED=true
GOAL_REMINDER_JOB_INTERVAL_MS=3600000
GOAL_REMINDER_DAYS_AHEAD=7

# --- Servidor ---
PORT=4000
NODE_ENV=development
